{
	"info": {
		"_postman_id": "magnus-enterprise-api-v1",
		"name": "Magnus Enterprise Employee Management System API",
		"description": "Postman API Collection for Enterprise Employee Management System (FastAPI + PostgreSQL)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login Super Admin",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@jala.com\",\n  \"password\": \"admin123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						}
					}
				},
				{
					"name": "Get Current User Profile",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/auth/me",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "me"]
						}
					}
				}
			]
		},
		{
			"name": "Employees",
			"item": [
				{
					"name": "List Employees (Paginated)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/employees?page=1&page_size=10",
							"host": ["{{baseUrl}}"],
							"path": ["employees"],
							"query": [
								{ "key": "page", "value": "1" },
								{ "key": "page_size", "value": "10" }
							]
						}
					}
				}
			]
		},
		{
			"name": "Master Data",
			"item": [
				{
					"name": "List Countries",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{accessToken}}" }
						],
						"url": {
							"raw": "{{baseUrl}}/countries",
							"host": ["{{baseUrl}}"],
							"path": ["countries"]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8000/api/v1"
		},
		{
			"key": "accessToken",
			"value": ""
		}
	]
}
